{
  "name": "@cipherman/pake-js",
  "version": "0.1.0",
  "description": "Auditable, standards-based Password-Authenticated Key Exchange (SPAKE2+ / CPace) for Node.js, Deno, Bun, and browsers. Built for regulated environments.",
  "keywords": [
    "pake",
    "spake2+",
    "spake2plus",
    "cpace",
    "rfc9383",
    "cpace-ristr255",
    "ristretto255",
    "p256",
    "key-exchange",
    "authenticated-key-exchange",
    "cryptography",
    "security",
    "hipaa",
    "medical"
  ],
  "license": "MIT",
  "author": "Ali Alp",
  "homepage": "https://github.com/alicommit-malp/pake-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alicommit-malp/pake-js.git"
  },
  "bugs": {
    "url": "https://github.com/alicommit-malp/pake-js/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./spake2plus": {
      "types": "./dist/spake2plus/index.d.ts",
      "import": "./dist/spake2plus/index.js",
      "require": "./dist/spake2plus/index.cjs"
    },
    "./cpace": {
      "types": "./dist/cpace/index.d.ts",
      "import": "./dist/cpace/index.js",
      "require": "./dist/cpace/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "THREAT_MODEL.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:vectors": "vitest run test/vectors",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=moderate --omit=dev",
    "size": "size-limit",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "size-limit": [
    {
      "name": "pake-js (esm, min+gzip)",
      "path": "dist/index.js",
      "limit": "35 kB"
    }
  ]
}
